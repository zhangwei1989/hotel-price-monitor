# ========== 数据源配置 ==========

# 携程 API (需要商务合作)
CTRIP_ENABLED=false
CTRIP_API_KEY=your_ctrip_api_key
CTRIP_API_SECRET=your_ctrip_api_secret

# Amadeus API (国际酒店集团: 万豪/凯悦/洲际等)
# 注册: https://developers.amadeus.com/register
AMADEUS_ENABLED=true
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_PRODUCTION=false

# RapidAPI (Booking.com 聚合)
# 注册: https://rapidapi.com/apidojo/api/booking-com
RAPIDAPI_ENABLED=true
RAPIDAPI_API_KEY=your_rapidapi_key

# ========== 飞书配置 ==========

# 飞书应用配置
FEISHU_APP_ID=cli_a92b495c63b8dcd9
FEISHU_APP_SECRET=mj4BdvpizUSMlORZbrNIQej61cJbVz1L

# 飞书多维表格配置
FEISHU_TABLE_APP_TOKEN=your_table_app_token
FEISHU_TABLE_ID=your_table_id

# ========== 服务配置 ==========

PORT=3000
NODE_ENV=development
